{
  "$schema": "https://raw.githubusercontent.com/nickel-roadster/tauri/dev/tooling/cli/schema.json",
  "productName": "FlashLocal",
  "version": "0.1.0",
  "identifier": "com.flashlocal.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FlashLocal",
        "width": 1024,
        "height": 768,
        "minWidth": 375,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["rpm", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
